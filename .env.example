# Ollama server configuration
# Change the URL if your Ollama server runs elsewhere.
SIGNALFORGE_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Chat model (examples: llama3, mistral, llama3.1:8b, etc.)
SIGNALFORGE_OLLAMA_MODEL=llama3

# Embedding model (examples: nomic-embed-text, mxbai-embed-large)
# Make sure you have pulled the model in Ollama:
#   ollama pull nomic-embed-text
SIGNALFORGE_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Timeout (seconds) for Ollama HTTP requests
SIGNALFORGE_OLLAMA_TIMEOUT=120

# Storage paths (override only if you want custom locations)
SIGNALFORGE_CHROMA_PERSIST_DIR=data/chroma_db
SIGNALFORGE_FAISS_PERSIST_DIR=data/faiss_db
SIGNALFORGE_UPLOADS_DIR=data/uploads
